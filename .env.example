# ===================================================================
# 青苗守护者 · 环境变量示例
# 用法：cp .env.example .env  然后按实际情况填写
# ===================================================================

# -------- 通用 --------
APP_ENV=development                   # development | production
TZ=Asia/Shanghai

# -------- Flask 后端 --------
FLASK_APP=run.py
FLASK_DEBUG=1
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ACCESS_TOKEN_EXPIRES=3600         # access token 过期时间（秒）
JWT_REFRESH_TOKEN_EXPIRES=2592000     # refresh token 过期时间（秒，30 天）

# -------- 前端 --------
VITE_API_BASE_URL=http://localhost:5000/api
VITE_WS_BASE_URL=ws://localhost:5000

# -------- MySQL（本地已安装即可）--------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=qingmiao
MYSQL_PASSWORD=qingmiao123
MYSQL_DATABASE=qingmiao_guardian

# 也可直接覆盖完整连接串
# DATABASE_URL=mysql+pymysql://qingmiao:qingmiao123@localhost:3306/qingmiao_guardian?charset=utf8mb4

# -------- 文件存储 --------
# STORAGE_BACKEND=local：本地磁盘（默认，无需任何依赖）
# STORAGE_BACKEND=minio：使用 MinIO（需自行启动 MinIO 服务并填写下方配置）
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./storage

# 仅在 STORAGE_BACKEND=minio 时需要
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_VIDEOS=qingmiao-videos
MINIO_BUCKET_FACES=qingmiao-faces
MINIO_BUCKET_REPORTS=qingmiao-reports
MINIO_SECURE=false

# -------- AI 推理服务 --------
AI_SERVICE_URL=http://localhost:8000
AI_DEVICE=cuda                        # cuda | cpu，演示机改为 cpu
AI_MODEL_DIR=./ai_service/models

# 全局 Mock 开关（true=全部走 mock，启动最快、演示最稳；false=尝试加载真实模型）
FORCE_MOCK=true

# -------- 通义千问（DashScope）--------
DASHSCOPE_API_KEY=sk-your-api-key-here
QWEN_MODEL=qwen-plus                  # qwen-turbo | qwen-plus | qwen-max
QWEN_VL_MODEL=qwen-vl-plus

# -------- 日志 --------
LOG_LEVEL=INFO
LOG_DIR=./logs

# -------- 上传限制 --------
MAX_VIDEO_SIZE_MB=500
ALLOWED_VIDEO_EXTS=mp4,avi,mov,mkv
